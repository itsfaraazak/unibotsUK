<?xml version="1.0"?>
<!--
  Unibots UK 2025-2026  ·  UniDesign2 Robot
  ══════════════════════════════════════════
  Generated from Fusion 360 binary-STL exports (mm units).
  All URDF values are in METRES.  mesh scale="0.001 0.001 0.001"
  converts Fusion mm → ROS metres at load time.

  Robot dimensions (from STL bounding boxes):
    Chassis base plate  :  150 × 175 × 5 mm
    Total height (est.) :  ~200 mm (fits 200 mm cube rule)
    Mecanum wheel diam  :  60 mm (user confirmed)
    Wheelbase           :  ~120 mm F↔B
    Track width         :  ~150 mm L↔R

  ROS2 / Gazebo Harmonic compatible.
  Drive plugin: libgazebo_ros_planar_move  (holonomic mecanum)
  Subscribed topic: /unibots/cmd_vel  (geometry_msgs/Twist)
-->
<robot name="unibots_robot_gazebo" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ╔══════════════════════════════════════════╗
       ║  PARAMETERS — edit here to tune model   ║
       ╚══════════════════════════════════════════╝ -->
  <xacro:property name="PI" value="3.14159265358979"/>

  <!-- Mesh unit conversion (Fusion exports in mm) -->
  <xacro:property name="ms" value="0.001 0.001 0.001"/>

  <!-- Mecanum wheel (not in Fusion — added as primitive) -->
  <xacro:property name="w_r"    value="0.030"/>   <!-- radius  = 60mm/2 -->
  <xacro:property name="w_w"    value="0.025"/>   <!-- width   = 25mm   -->
  <xacro:property name="w_mass" value="0.100"/>   <!-- 100 g per wheel  -->
  <xacro:property name="w_x"    value="0.060"/>   <!-- half wheelbase   -->
  <xacro:property name="w_y"    value="0.075"/>   <!-- half track       -->

  <!-- ╔══════════════════════════════════════════╗
       ║  MATERIALS                              ║
       ╚══════════════════════════════════════════╝ -->
  <material name="red">    <color rgba="0.80 0.10 0.10 1.0"/></material>
  <material name="orange"> <color rgba="0.95 0.55 0.00 1.0"/></material>
  <material name="yellow"> <color rgba="0.95 0.80 0.00 1.0"/></material>
  <material name="green">  <color rgba="0.10 0.70 0.10 1.0"/></material>
  <material name="blue">   <color rgba="0.10 0.20 0.80 1.0"/></material>
  <material name="grey">   <color rgba="0.50 0.50 0.50 1.0"/></material>
  <material name="white">  <color rgba="0.90 0.90 0.90 1.0"/></material>
  <material name="black">  <color rgba="0.10 0.10 0.10 1.0"/></material>

  <!-- ╔══════════════════════════════════════════╗
       ║  INERTIA HELPERS                        ║
       ╚══════════════════════════════════════════╝ -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(y*y+z*z)/12}" ixy="0" ixz="0"
               iyy="${m*(x*x+z*z)/12}" iyz="0"
               izz="${m*(x*x+y*y)/12}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cyl_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0"
               iyy="${m*(3*r*r+h*h)/12}" iyz="0"
               izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <!-- ╔══════════════════════════════════════════╗
       ║  MECANUM WHEEL MACRO  (used 4×)         ║
       ╚══════════════════════════════════════════╝ -->
  <xacro:macro name="mecanum_wheel" params="prefix ox oy">
    <link name="${prefix}_wheel">
      <visual>
        <geometry><cylinder radius="${w_r}" length="${w_w}"/></geometry>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
        <material name="yellow"/>
      </visual>
      <collision>
        <geometry><cylinder radius="${w_r}" length="${w_w}"/></geometry>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      </collision>
      <xacro:cyl_inertia m="${w_mass}" r="${w_r}" h="${w_w}"/>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${prefix}_wheel"/>
      <origin xyz="${ox} ${oy} ${-0.0025}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.01" friction="0.1"/>
    </joint>

    <gazebo reference="${prefix}_wheel">
      <mu1>1.0</mu1><mu2>0.5</mu2>
      <kp>1000000.0</kp><kd>10.0</kd>
      <minDepth>0.001</minDepth>
      <material>Gazebo/Yellow</material>
    </gazebo>
  </xacro:macro>

  <!-- ╔══════════════════════════════════════════════════════════╗
       ║  BASE LINK  — bottom plate (150×175×5 mm)              ║
       ║  Origin = geometric centre of plate, at wheel-axle Z   ║
       ╚══════════════════════════════════════════════════════════╝ -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="package://unibots_robot_gazebo/meshes/bottom_plate_updated_1_Body4.stl"
              scale="${ms}"/>
      </geometry>
      <!-- Cancel Fusion origin: centre was at (60, 11.2, 13.8) mm -->
      <origin xyz="-0.060 -0.0112 -0.0138" rpy="0 0 0"/>
      <material name="red"/>
    </visual>
    <collision>
      <geometry><box size="0.150 0.175 0.005"/></geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <xacro:box_inertia m="0.300" x="0.150" y="0.175" z="0.005"/>
  </link>
  <gazebo reference="base_link"><material>Gazebo/Red</material></gazebo>

  <!-- ╔══════════════════════════════════════════╗
       ║  HELPER MACRO: fixed STL link + joint   ║
       ╚══════════════════════════════════════════╝ -->
  <xacro:macro name="fixed_link" params="name mesh ox oy oz col mat gaz_mat mass sx sy sz">
    <link name="${name}">
      <visual>
        <geometry>
          <mesh filename="package://unibots_robot_gazebo/meshes/${mesh}" scale="${ms}"/>
        </geometry>
        <origin xyz="-0.060 -0.0112 -0.0138" rpy="0 0 0"/>
        <material name="${mat}"/>
      </visual>
      <collision>
        <geometry><box size="${sx} ${sy} ${sz}"/></geometry>
      </collision>
      <xacro:box_inertia m="${mass}" x="${sx}" y="${sy}" z="${sz}"/>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="${col}"/>
      <child  link="${name}"/>
      <origin xyz="${ox} ${oy} ${oz}" rpy="0 0 0"/>
    </joint>
    <gazebo reference="${name}"><material>${gaz_mat}</material></gazebo>
  </xacro:macro>

  <!-- ╔══════════════════════════════════════════════════════════╗
       ║  ALL STRUCTURAL LINKS (real offsets from STL analysis) ║
       ╚══════════════════════════════════════════════════════════╝ -->

  <!-- Top plate 190×190×5 mm -->
  <xacro:fixed_link name="top_plate"
    mesh="top_plate_updated_1_Body3.stl"
    ox="0.0000" oy="0.0075" oz="0.0550"
    col="base_link" mat="red" gaz_mat="Gazebo/Red"
    mass="0.200" sx="0.190" sy="0.190" sz="0.005"/>

  <!-- Columns (×4) -->
  <xacro:fixed_link name="col_extruded_1"
    mesh="column_extruded_1_Body1.stl"
    ox="-0.0800" oy="0.0877" oz="0.0950"
    col="base_link" mat="white" gaz_mat="Gazebo/White"
    mass="0.040" sx="0.026" sy="0.026" sz="0.075"/>

  <xacro:fixed_link name="col_extruded_2"
    mesh="column_extruded_2_Body1.stl"
    ox="0.0800" oy="0.0877" oz="0.0950"
    col="base_link" mat="white" gaz_mat="Gazebo/White"
    mass="0.040" sx="0.026" sy="0.026" sz="0.075"/>

  <xacro:fixed_link name="col_non_extruded_1"
    mesh="column_NONextruded_1_Body3.stl"
    ox="-0.0800" oy="0.0260" oz="0.0950"
    col="base_link" mat="white" gaz_mat="Gazebo/White"
    mass="0.040" sx="0.026" sy="0.026" sz="0.075"/>

  <xacro:fixed_link name="col_non_extruded_2"
    mesh="column_NONextruded_2_Body3.stl"
    ox="0.0800" oy="0.0260" oz="0.0950"
    col="base_link" mat="white" gaz_mat="Gazebo/White"
    mass="0.040" sx="0.026" sy="0.026" sz="0.075"/>

  <!-- Middle supports (×3) -->
  <xacro:fixed_link name="mid_support_1"
    mesh="middle_support_1_Body2.stl"
    ox="-0.0655" oy="0.0076" oz="0.0275"
    col="base_link" mat="grey" gaz_mat="Gazebo/Grey"
    mass="0.015" sx="0.009" sy="0.009" sz="0.050"/>

  <xacro:fixed_link name="mid_support_2"
    mesh="middle_support_2_Body2.stl"
    ox="0.0000" oy="-0.0725" oz="0.0275"
    col="base_link" mat="grey" gaz_mat="Gazebo/Grey"
    mass="0.015" sx="0.009" sy="0.009" sz="0.050"/>

  <xacro:fixed_link name="mid_support_3"
    mesh="middle_support_3_Body2.stl"
    ox="0.0655" oy="0.0076" oz="0.0275"
    col="base_link" mat="grey" gaz_mat="Gazebo/Grey"
    mass="0.015" sx="0.009" sy="0.009" sz="0.050"/>

  <!-- Motor supports front (fr = front of robot) -->
  <xacro:fixed_link name="motor_support_fr1"
    mesh="new_motor_support_fr_1_Body3.stl"
    ox="-0.0439" oy="-0.0398" oz="0.0275"
    col="base_link" mat="orange" gaz_mat="Gazebo/Orange"
    mass="0.025" sx="0.011" sy="0.023" sz="0.050"/>

  <xacro:fixed_link name="motor_support_fr2"
    mesh="new_motor_support_fr_2_Body3.stl"
    ox="0.0439" oy="0.0550" oz="0.0275"
    col="base_link" mat="orange" gaz_mat="Gazebo/Orange"
    mass="0.025" sx="0.011" sy="0.023" sz="0.050"/>

  <!-- Motor supports back -->
  <xacro:fixed_link name="motor_support_br1"
    mesh="new_motor_support_br_1_Body6.stl"
    ox="-0.0439" oy="0.0550" oz="0.0275"
    col="base_link" mat="orange" gaz_mat="Gazebo/Orange"
    mass="0.025" sx="0.011" sy="0.023" sz="0.050"/>

  <xacro:fixed_link name="motor_support_br2"
    mesh="new_motor_support_br_2_Body6.stl"
    ox="0.0439" oy="-0.0398" oz="0.0275"
    col="base_link" mat="orange" gaz_mat="Gazebo/Orange"
    mass="0.025" sx="0.011" sy="0.023" sz="0.050"/>

  <!-- Storage boxes -->
  <xacro:fixed_link name="main_storage"
    mesh="Main_Storage_1_Body1.stl"
    ox="0.0588" oy="-0.0435" oz="0.1135"
    col="base_link" mat="grey" gaz_mat="Gazebo/DarkGrey"
    mass="0.060" sx="0.0725" sy="0.088" sz="0.112"/>

  <xacro:fixed_link name="battery_storage"
    mesh="Battery_Storage_1_Body2.stl"
    ox="-0.0588" oy="-0.0483" oz="0.1125"
    col="base_link" mat="blue" gaz_mat="Gazebo/Blue"
    mass="0.200" sx="0.0725" sy="0.0785" sz="0.110"/>

  <xacro:fixed_link name="additional_storage"
    mesh="Additional_Storage_1_Body1.stl"
    ox="-0.0192" oy="-0.0725" oz="0.1055"
    col="base_link" mat="grey" gaz_mat="Gazebo/DarkGrey"
    mass="0.040" sx="0.1125" sy="0.030" sz="0.090"/>

  <!-- Ramp (ball collection funnel) -->
  <xacro:fixed_link name="ramp"
    mesh="Ramp_1_Body1.stl"
    ox="0.0000" oy="-0.0165" oz="0.0800"
    col="base_link" mat="green" gaz_mat="Gazebo/Green"
    mass="0.080" sx="0.060" sy="0.118" sz="0.190"/>

  <!-- Claw -->
  <xacro:fixed_link name="claw"
    mesh="claw_1_Body2.stl"
    ox="-0.0019" oy="0.0411" oz="0.0409"
    col="base_link" mat="black" gaz_mat="Gazebo/Black"
    mass="0.060" sx="0.048" sy="0.036" sz="0.104"/>

  <!-- Servo holder -->
  <xacro:fixed_link name="servo_holder"
    mesh="Servo_Holder_1_Body1.stl"
    ox="-0.0535" oy="0.0357" oz="0.0740"
    col="base_link" mat="grey" gaz_mat="Gazebo/Grey"
    mass="0.020" sx="0.034" sy="0.0695" sz="0.033"/>

  <!-- Handle -->
  <xacro:fixed_link name="handle"
    mesh="handle_1_Body2.stl"
    ox="-0.0099" oy="0.0959" oz="0.1687"
    col="base_link" mat="black" gaz_mat="Gazebo/Black"
    mass="0.015" sx="0.146" sy="0.010" sz="0.045"/>

  <!-- Tilted platform (sensor/camera mount) -->
  <xacro:fixed_link name="platform"
    mesh="Platform_tilted_1_Body1.stl"
    ox="0.0000" oy="0.0522" oz="0.1568"
    col="base_link" mat="grey" gaz_mat="Gazebo/DarkGrey"
    mass="0.080" sx="0.190" sy="0.100" sz="0.048"/>

  <!-- ╔══════════════════════════════════════════╗
       ║  MECANUM WHEELS  (4 primitive cylinders) ║
       ╚══════════════════════════════════════════╝ -->
  <!--
    Wheel positions (measured from base_link centre):
      FR (+x forward, -y right), FL (+x, +y left)
      BR (-x back,   -y right), BL (-x,  +y left)
  -->
  <xacro:mecanum_wheel prefix="front_right" ox=" ${w_x}" oy="${-w_y}"/>
  <xacro:mecanum_wheel prefix="front_left"  ox=" ${w_x}" oy=" ${w_y}"/>
  <xacro:mecanum_wheel prefix="back_right"  ox="${-w_x}" oy="${-w_y}"/>
  <xacro:mecanum_wheel prefix="back_left"   ox="${-w_x}" oy=" ${w_y}"/>

  <!-- ╔══════════════════════════════════════════╗
       ║  CAMERA FRAME                           ║
       ╚══════════════════════════════════════════╝ -->
  <link name="camera_link">
    <visual>
      <geometry><box size="0.020 0.020 0.020"/></geometry>
      <material name="black"/>
    </visual>
    <xacro:box_inertia m="0.030" x="0.020" y="0.020" z="0.020"/>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="platform"/>
    <child  link="camera_link"/>
    <origin xyz="0.0 0.0 0.030" rpy="0 -0.26 0"/><!-- ~15° tilt down -->
  </joint>

  <!-- Gazebo camera sensor -->
  <gazebo reference="camera_link">
    <sensor name="robot_camera" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.396</horizontal_fov><!-- 80° -->
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.02</near><far>5.0</far></clip>
      </camera>
      <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/unibots</namespace>
          <remapping>image_raw:=camera/image_raw</remapping>
          <remapping>camera_info:=camera/camera_info</remapping>
        </ros>
        <frame_name>camera_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ╔══════════════════════════════════════════╗
       ║  IMU                                    ║
       ╚══════════════════════════════════════════╝ -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 0.010" rpy="0 0 0"/>
  </joint>
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <namespace>/unibots</namespace>
          <remapping>~/out:=imu/data</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ╔════════════════════════════════════════════════════════╗
       ║  DRIVE PLUGIN — holonomic mecanum (planar_move)       ║
       ║  Publishes /unibots/odom                              ║
       ║  Subscribes /unibots/cmd_vel (geometry_msgs/Twist)   ║
       ╚════════════════════════════════════════════════════════╝ -->
  <gazebo>
    <plugin name="mecanum_drive" filename="libgazebo_ros_planar_move.so">
      <ros>
        <namespace>/unibots</namespace>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      <update_rate>100</update_rate>
      <publish_rate>20</publish_rate>
      <robot_base_frame>base_link</robot_base_frame>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <odometry_frame>odom</odometry_frame>
    </plugin>
  </gazebo>

</robot>
