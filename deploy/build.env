# ============================================================================
# deploy/build.env — SINGLE SOURCE OF TRUTH for the optimized Pi 5 build.
# ============================================================================
# Edited by both the Docker image build AND the Ansible playbook (and build.sh).
# Change a value here and rebuild — nothing else needs touching.
#
# Target: Raspberry Pi 5 → Broadcom BCM2712, 4× Arm Cortex-A76 @ 2.4 GHz,
#         ARMv8.2-A + crypto extensions. Ubuntu 26.04 (aarch64).
# ----------------------------------------------------------------------------

# ROS 2 distribution (must match the apt repo / Ubuntu 26.04 pairing).
ROS_DISTRO=lyrical

# Ubuntu release codename — the apt suite for the ROS repo and the base rootfs.
# Ubuntu 26.04 = "resolute". Used by deploy/cross-build/ only.
UBUNTU_CODENAME=resolute

# ---- Pi 5 CPU targeting --------------------------------------------------
# cortex-a76+crypto enables the A76 pipeline model + AES/SHA/CRC instructions.
# This is an EXPLICIT target (not -mcpu=native) so every identical Pi 5 unit
# produces a byte-for-byte comparable, reproducible binary.
PI5_CPU="cortex-a76+crypto"
PI5_TUNE="cortex-a76"

# ---- Optimization level --------------------------------------------------
OPT_LEVEL="-O3"

# Aggressive-but-SAFE extra flags (numerically lossless).
#   -funroll-loops          unroll hot loops (NCNN / Kalman matmuls)
#   -fomit-frame-pointer    free up x29 as a GP register
#   -fno-plt                direct calls, skip PLT indirection
#   -fno-semantic-interposition  allow inlining across the shared lib boundary
#   -pipe                   build faster (no temp files)
EXTRA_CXX_FLAGS="-funroll-loops -fomit-frame-pointer -fno-plt -fno-semantic-interposition -pipe"

# ---- Link-time optimization ---------------------------------------------
# 1 = enable LTO (-flto=auto + CMAKE_INTERPROCEDURAL_OPTIMIZATION). Big win,
#     slower link. 0 = off if a link ever fails on match day.
ENABLE_LTO=1

# ---- DANGER ZONE ---------------------------------------------------------
# -ffast-math reorders FP ops and assumes no NaN/Inf. It WILL degrade the
# Kalman tracker (spatial_memory) and the EKF (localization). Leave at 0.
# Only flip to 1 if you have measured it and accept the accuracy hit.
ENABLE_FAST_MATH=0
