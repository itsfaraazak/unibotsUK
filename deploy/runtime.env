# ============================================================================
# deploy/runtime.env — MATCH-DAY runtime config (NOT build flags).
# ============================================================================
# Read by the systemd service / docker-compose at launch. Change these between
# rounds without rebuilding anything: edit, then restart the service.
#   Docker:  docker compose --env-file deploy/runtime.env up -d
#   systemd: edit, then `sudo systemctl restart unibots`
# ----------------------------------------------------------------------------

# Scoring wall assigned by the judges: north | east | south | west
HOME_ZONE=north

# Motion controller: mpc (default) | apf (fallback)
CONTROLLER=mpc

# Launch the GPIO/I2C motor + servo bridges (true on the real robot).
HARDWARE=true

# Launch the V4L2 camera_node (true on the real robot).
CAMERA=true

# Launch AprilTag + EKF localization (provides /odom/filtered).
LOCALIZATION=true

# Use the simulation clock (false for a real match).
USE_SIM_TIME=false

# ROS 2 DDS domain — keep robots on the same field from cross-talking.
ROS_DOMAIN_ID=42
